APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=your-project.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.your-project-ref
DB_PASSWORD=your-database-password
DB_SSLMODE=require
DB_CONNECT_TIMEOUT=5
# Reuse the DB connection across requests (big speedup with a distant database).
# Set to false for high-concurrency production + use the transaction pooler (6543).
DB_PERSISTENT=true

# ── Database retention / storage guard ───────────────────────────────────────
# Supabase free tier is ~500 MB. The daily `retention:check` command alerts admins
# when usage crosses these thresholds and auto-prunes only transient rows
# (expired sessions, old read notifications). It never deletes student, financial,
# activity, or audit data on its own. RETENTION_AUDIT_DAYS is floored at 365 (policy).
DB_CAP_MB=500
RETENTION_WARN_PERCENT=75
RETENTION_CRITICAL_PERCENT=90
RETENTION_SESSION_DAYS=7
RETENTION_READ_NOTIF_DAYS=90
RETENTION_AUDIT_DAYS=365

# Local-disk session/cache avoid a remote round-trip to the database on every
# request (important when the DB is a distant Supabase instance).
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Default is "log" (emails written to storage/logs, nothing sent).
# To send announcement Gmail copies via the SCC Google Workspace, switch to smtp:
#   MAIL_MAILER=smtp
#   MAIL_HOST=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_SCHEME=null            # STARTTLS on 587 (use "smtps" + port 465 for SSL)
#   MAIL_USERNAME=clubsync@sccpag.edu.ph
#   MAIL_PASSWORD="<google-workspace-app-password>"   # 16-char App Password (2FA required)
#   MAIL_FROM_ADDRESS="clubsync@sccpag.edu.ph"
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Google Calendar sync (institutional Google Workspace, service account + domain-wide delegation).
# Setup (Google Cloud Console + Workspace super-admin):
#   1. Create a service account, enable the Google Calendar API, generate a JSON key.
#   2. Note the service account's "Client ID"; in the Admin console
#      (Security > API Controls > Domain-wide delegation) authorize that Client ID
#      for scope: https://www.googleapis.com/auth/calendar
#   3. Place the JSON key at storage/app/google/service-account.json (git-ignored).
#   4. Set GOOGLE_CALENDAR_IMPERSONATE to a real @sccpag.edu.ph user who owns the calendar.
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_IMPERSONATE=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=Asia/Manila

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Firebase (authentication + realtime database) ─────────────────────────────
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_DATABASE_URL=

# ── Google Gemini (AI announcement drafting) ──────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Outbound HTTP fail-fast (Firebase/Gemini) when offline ────────────────────
HTTP_CONNECT_TIMEOUT=5
