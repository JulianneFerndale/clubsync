# Keep the build context small and never ship local secrets / artifacts.
.git
.github
.idea
.vscode
node_modules
vendor
public/build
public/hot
storage/*.key
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
.env
.env.*
!.env.example
tests
phpunit.xml
README.md
DEPLOY.md
*.sqlite
tmp_diag.php
